# Solar Control API Configuration
# Point this to your solar-control instance (NOT individual solar-host servers)
VITE_SOLAR_CONTROL_URL=http://localhost:8000
VITE_SOLAR_CONTROL_API_KEY=your-solar-control-api-key

# Optional server-side gate for the WebUI.
# This is read by the Express server and the Vite dev server; do not use a VITE_ prefix.
# SOLAR_WEBUI_AUTH_KEY=change-me

# Note: The VITE_ prefix is required by Vite to expose these environment variables to the browser.
# Copy this file to .env and update with your actual values.
